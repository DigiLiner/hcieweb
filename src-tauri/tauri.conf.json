{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "hcie",
  "version": "2.5.1",
  "identifier": "com.hc.hcie",
  "build": {
    "frontendDist": "../tauri-dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HC Image Editor",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
