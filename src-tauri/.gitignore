# Generated by Cargo
# will have compiled files and executables
/target/
/gen/schemas
# --- IDE ve Sistem Dosyaları ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.tmp

# --- Node.js (Frontend) Bağımlılıkları ---
# İşletim sistemleri arasında en çok sorun çıkaran klasör budur.
# Her sistemde (Win/Lin) kendi 'npm install' komutunu çalıştırmalısın.
node_modules/
dist/
build/
.env
.env.*
.eslintcache
.stylelintcache

# --- Rust (Tauri Backend) Bağımlılıkları ---
# Rust'ın derlenmiş çıktıları burada tutulur ve tamamen işletim sistemine özeldir.
# Windows'ta derlenen dosya Linux'ta çalışmaz, bu yüzden senkronize edilmemelidir.
src-tauri/target/

# --- Tauri Özel Dosyaları ---
# Otomatik oluşturulan ve her kurulumda değişebilen dosyalar.
src-tauri/gen/
src-tauri/bin/

# --- Paket Yöneticisi Kilit Dosyaları (Opsiyonel) ---
# Eğer farklı paket yöneticileri (npm, pnpm, yarn) arasında geçiş yapıyorsan 
# bunları da görmezden gelebilirsin ama ekip çalışmasında genellikle tutulur.
# npm-debug.log*
# yarn-debug.log*
# yarn-error.log*
# pnpm-debug.log*