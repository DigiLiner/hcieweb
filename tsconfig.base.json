{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@hcie/*": [
        "../hcie-*/src"
      ]
    },
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "strict": true,
    "declaration": true,
    "composite": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}